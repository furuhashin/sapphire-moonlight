{
	"name": "Sapphire Moonlight",
	"type": "dark",
	"colors": {
		"editor.background": "#1b1e23",
		"editor.foreground": "#f8f8f2",
		"sideBar.background": "#15171c",
		"activityBar.background": "#15171c",
		"editorLineNumber.foreground": "#4b5263",
		"editorLineNumber.activeForeground": "#dcc6e0",
		"statusBar.background": "#00e0e0",
		"statusBar.foreground": "#1b1e23"
	},
	"tokenColors": [
		{
			"name": "Comments",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "foreground": "#4c9474", "fontStyle": "italic" }
		},
		{
			"name": "Keywords",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#dcc6e0" }
		},
		// {
		// 	"name": "Keywords",
		// 	"scope": ["keyword", "storage.type", "storage.modifier"],
		// 	"settings": { "foreground": "#817ffa" }
		// },

		{
			"name": "Operators",
			"scope": ["keyword.operator"],
			"settings": { "foreground": "#3ed4d4" }
		},
		{
			"name": "Functions",
			"scope": ["entity.name.function", "support.function", "meta.function-call", "variable.function"],
			"settings": { "foreground": "#3ed4d4" }
		},
		{
			"name": "Types and Classes",
			"scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
			"settings": { "foreground": "#e8c44e" }
		},
		{
			"name": "Variables",
			"scope": ["variable", "variable.other"],
			"settings": { "foreground": "#b09ffa" }
		},
		{
			"name": "Variable Sigils (PHP $, Ruby @ / @@)",
			"scope": ["punctuation.definition.variable.php", "punctuation.definition.variable.ruby"],
			"settings": { "foreground": "#b09ffa" }
		},
		{
			"name": "Variable Parameters",
			"scope": ["variable.parameter"],
			"settings": { "foreground": "#5fa8e8" }
		},
		{
			"name": "Language Variables",
			"scope": ["variable.language"],
			"settings": { "foreground": "#ffa07a", "fontStyle": "italic" }
		},
		{
			"name": "Strings",
			"scope": ["string", "punctuation.definition.string"],
			"settings": { "foreground": "#9fc15e" }
		},
		{
			"name": "Escape Characters",
			"scope": ["constant.character.escape"],
			"settings": { "foreground": "#9fc15e" }
		},
		{
			"name": "Template / Interpolation Placeholders",
			"scope": [
				"punctuation.definition.template-expression.begin",
				"punctuation.definition.template-expression.end",
				"punctuation.definition.interpolation.begin",
				"punctuation.definition.interpolation.end"
			],
			"settings": { "foreground": "#ffa07a" }
		},
		{
			"name": "Regular Expressions",
			"scope": ["string.regexp"],
			"settings": { "foreground": "#ffa07a" }
		},
		{
			"name": "Numbers and Literals",
			"scope": ["constant.numeric", "constant.language"],
			"settings": { "foreground": "#cf609f" }
		},
		{
			"name": "Constants",
			"scope": ["support.constant", "constant.other"],
			"settings": { "foreground": "#e8c44e" }
		},
		{
			"name": "Built-in Variables",
			"scope": ["support.variable"],
			"settings": { "foreground": "#e8c44e" }
		},
		{
			"name": "Punctuation",
			"scope": ["punctuation"],
			"settings": { "foreground": "#f8f8f2" }
		},
		{
			"name": "Tags",
			"scope": ["entity.name.tag"],
			"settings": { "foreground": "#3ed4d4" }
		},
		{
			"name": "Attributes",
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#e8c44e" }
		},
		{
			"name": "Decorators and Annotations",
			"scope": ["meta.decorator", "punctuation.decorator", "meta.annotation"],
			"settings": { "foreground": "#e8c44e" }
		},
		{
			"name": "Namespace and Modules",
			"scope": ["entity.name.namespace", "entity.name.module"],
			"settings": { "foreground": "#f8f8f2" }
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#ffa07a" }
		},
		{
			"name": "Markdown Headings",
			"scope": ["heading.1.markdown", "heading.2.markdown", "heading.3.markdown", "heading.4.markdown", "heading.5.markdown", "heading.6.markdown", "markup.heading"],
			"settings": { "foreground": "#3ed4d4", "fontStyle": "bold" }
		},
		{
			"name": "Markdown Heading Punctuation",
			"scope": ["punctuation.definition.heading.markdown"],
			"settings": { "foreground": "#3ed4d4", "fontStyle": "bold" }
		},
		{
			"name": "Markdown Bold",
			"scope": ["markup.bold"],
			"settings": { "foreground": "#e8c44e", "fontStyle": "bold" }
		},
		{
			"name": "Markdown Italic",
			"scope": ["markup.italic"],
			"settings": { "foreground": "#dcc6e0", "fontStyle": "italic" }
		},
		{
			"name": "Markdown Inline Code",
			"scope": ["markup.inline.raw"],
			"settings": { "foreground": "#9fc15e" }
		},
		{
			"name": "Markdown Strikethrough",
			"scope": ["markup.strikethrough"],
			"settings": { "foreground": "#7082ab", "fontStyle": "strikethrough" }
		},
		{
			"name": "Markdown Links",
			"scope": ["markup.underline.link", "string.other.link"],
			"settings": { "foreground": "#b09ffa" }
		},
		{
			"name": "Markdown Blockquote",
			"scope": ["markup.quote"],
			"settings": { "foreground": "#ffa07a", "fontStyle": "italic" }
		},
		{
			"name": "Markdown List Marker",
			"scope": ["punctuation.definition.list.begin.markdown"],
			"settings": { "foreground": "#dcc6e0" }
		}
	]
}